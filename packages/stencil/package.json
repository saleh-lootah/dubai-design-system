{
  "name": "@dubai-design-system/components-js",
  "version": "3.12.16",
  "private": false,
  "description": "JavaScript package for the Digital Dubai Design System, offering reusable, customizable components for seamless integration into web applications",
  "main": "dist/index.cjs.js",
  "module": "dist/index.js",
  "types": "dist/types/index.d.ts",
  "collection": "dist/collection/collection-manifest.json",
  "collection:main": "dist/collection/index.js",
  "unpkg": "dist/stencil/stencil.esm.js",
  "exports": {
    ".": {
      "import": "./dist/stencil/stencil.esm.js",
      "require": "./dist/stencil/stencil.cjs.js"
    },
    "./dist/*": {
      "import": "./dist/*",
      "types": "./dist/*"
    },
    "./components/*": {
      "import": "./dist/components/*.js",
      "types": "./dist/components/*.d.ts"
    },
    "./loader": {
      "import": "./loader/index.js",
      "require": "./loader/index.cjs",
      "types": "./loader/index.d.ts"
    }
  },
  "repository": {
    "type": "git"
  },
  "files": [
    "dist/",
    "loader/",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "stencil build",
    "start": "stencil build --dev --watch --serve",
    "test": "stencil test --spec --e2e",
    "test.watch": "stencil test --spec --e2e --watchAll",
    "generate": "stencil generate",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "release": "standard-version"
  },
  "dependencies": {
    "chromatic": "^11.11.0",
    "material-icons": "^1.13.14",
    "material-symbols": "^0.28.2",
    "quill": "^2.0.2",
    "react-markdown": "^9.0.1"
  },
  "devDependencies": {
    "@stencil/angular-output-target": "^0.10.2",
    "@stencil/core": "^4.7.0",
    "@stencil/react-output-target": "^0.8.2",
    "@stencil/vue-output-target": "^0.8.8",
    "@storybook/addon-a11y": "^8.2.7",
    "@storybook/addon-essentials": "^8.1.11",
    "@storybook/addon-interactions": "^8.2.7",
    "@storybook/addon-links": "^8.1.11",
    "@storybook/addon-webpack5-compiler-swc": "^1.0.4",
    "@storybook/addons": "^7.6.17",
    "@storybook/blocks": "^8.1.11",
    "@storybook/test": "^8.2.7",
    "@storybook/web-components": "^8.1.11",
    "@storybook/web-components-webpack5": "^8.1.11",
    "@types/jest": "^29.5.6",
    "@types/node": "^16.18.11",
    "@whitespace/storybook-addon-html": "^6.1.1",
    "jest": "^29.7.0",
    "jest-cli": "^29.7.0",
    "lit": "^3.1.4",
    "prettier": "^3.3.3",
    "puppeteer": "^21.9.0",
    "react-syntax-highlighter": "^15.5.0",
    "standard-version": "^9.5.0",
    "storybook": "^8.1.11"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "UNLICENSED",
  "gitHead": "e9aa73742f2bfa5a5534f34888fef366880c7e4d"
}
