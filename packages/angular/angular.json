{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "stencil-wrapper": {
      "projectType": "library",
      "root": "projects/stencil-wrapper",
      "sourceRoot": "projects/stencil-wrapper/src",
      "prefix": "lib",
      "architect": {
        "build": {
          "builder": "@angular/build:ng-packagr",
          "options": {
            "project": "projects/stencil-wrapper/ng-package.json"
          },
          "configurations": {
            "production": {
              "tsConfig": "projects/stencil-wrapper/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "projects/stencil-wrapper/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "tsConfig": "projects/stencil-wrapper/tsconfig.spec.json",
            "polyfills": [
              "zone.js",
              "zone.js/testing"
            ]
          }
        }
      }
    }
  },
  "cli": {
    "analytics": "948ec478-bdd2-4bd6-821d-cb10bbbc6fe1"
  }
}
